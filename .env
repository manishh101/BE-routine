# MongoDB Atlas Connection URI - Using bctroutine database only
MONGODB_URI=your_mongodb_uri_here
MONGODB_ATLAS_URI=your_mongodb_atlas_uri_here

# Legacy connection string (for backward compatibility) - Using bctroutine database only
MONGO_URI=your_legacy_mongo_uri_here

# Other Environment Variables
NODE_ENV=development
PORT=7102
FRONTEND_URL=http://localhost:7105
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30d

# RabbitMQ Configuration (disabled for now)
USE_RABBITMQ=false
RABBITMQ_URL=amqp://localhost
